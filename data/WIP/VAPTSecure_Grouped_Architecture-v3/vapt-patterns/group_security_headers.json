{
  "group_id": "security_headers",
  "target_file": "{ABSPATH}.htaccess",
  "begin_marker": "# BEGIN VAPT_SECURITY_HEADERS",
  "end_marker": "# END VAPT_SECURITY_HEADERS",
  "merge_strategy": "headers_union",
  "rules": {
    "headers": {
      "X-Frame-Options": "SAMEORIGIN",
      "X-Content-Type-Options": "nosniff",
      "Referrer-Policy": "no-referrer-when-downgrade"
    }
  }
}