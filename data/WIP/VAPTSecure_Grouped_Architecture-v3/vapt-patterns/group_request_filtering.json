{
  "group_id": "request_filtering",
  "target_file": "{ABSPATH}.htaccess",
  "begin_marker": "# BEGIN VAPT_REQUEST_FILTERING",
  "end_marker": "# END VAPT_REQUEST_FILTERING",
  "merge_strategy": "rewrite_union",
  "rules": {
    "rewrite_conditions": [
      "RewriteCond %{QUERY_STRING} (\\../|%2e%2e)",
      "RewriteCond %{REQUEST_METHOD} ^(TRACE|DELETE)"
    ],
    "rewrite_rule": "RewriteRule .* - [F,L]"
  }
}